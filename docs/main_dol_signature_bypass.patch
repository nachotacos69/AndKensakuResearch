# And-Kensaku main.dol signature-bypass patch
#
# Target  : RK3J01 (安藤ケンサク) main.dol
# Function: wordUpdateChkTr2Signature @ 0x80030d1c
# Purpose : force the per-file word-data signature check to always pass,
#           so edited upd/*.tr2 files load instead of triggering
#           gameSetUpdateDataBroken + assert (word_update.c:80) + crash.
#
# The comparator at 0x80031668 returns NON-ZERO on a signature MATCH.
# Each verdict point branches to the clean exit (0x80030ea0) on match and
# otherwise falls through into the error/assert path. Making both branches
# unconditional sends every file to the clean exit regardless of signature.
#
# 2 sites, 4 bytes each, 3 bytes changed per site, file size unchanged.
#
# --- format: <file_offset> <virtual_addr> <original> -> <patched>  ; <disasm>

# Site 1
0x0001FF64  0x80030E24  40 82 00 7C  ->  48 00 00 7C   ; bne 0x80030ea0  ->  b 0x80030ea0

# Site 2
0x0001FFA4  0x80030E64  40 82 00 3C  ->  48 00 00 3C   ; bne 0x80030ea0  ->  b 0x80030ea0

# Context (Site 1):
#   80030e1c  bl    0x80031668      ; r3 = signature comparator result (nonzero == match)
#   80030e20  cmpwi r3, 0
#   80030e24  bne   0x80030ea0      ; <-- PATCH: make unconditional 'b 0x80030ea0'
#   80030e28  ...                   ; (original mismatch path: "Signature Error!!!" + assert)
#   80030ea0  ...                   ; clean exit (finalizer + return)
